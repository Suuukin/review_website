{% extends 'base.j2' %}

{% block content %}
<h1 class="mb-4">Tags</h1>

{% if session.get('logged_in') %}
<div class="mb-3">
  <form method="post" action="{{ url_for('cleanup_tags') }}" class="d-inline">
    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
    <button type="submit" class="btn btn-outline-warning btn-sm">🧹 Remove Unused Tags</button>
  </form>
</div>
{% endif %}

{% if tags %}
<div class="d-flex flex-wrap gap-3">
  {% for tag in tags %}
  <div class="d-flex align-items-center gap-2">
    <a href="{{ url_for('index') }}?q={{ tag['title'] | urlencode }}"
       class="tag-badge"
       style="background-color: {{ tag['color'] or '#4a6984' }}; text-decoration: none;">
      {{ tag['title'] }}
      <span class="ms-1 opacity-75">({{ tag['usage_count'] }})</span>
    </a>
    {% if session.get('logged_in') %}
    <div class="d-flex gap-1">
      <button type="button" class="btn btn-sm btn-outline-light py-0 px-1"
              data-bs-toggle="modal" data-bs-target="#editTagModal"
              data-tag-id="{{ tag['tag_id'] }}"
              data-tag-title="{{ tag['title'] }}"
              data-tag-color="{{ tag['color'] or '#4a6984' }}"
              title="Edit tag">✏️</button>
      <form method="post" action="{{ url_for('delete_tag', tag_id=tag['tag_id']) }}" class="d-inline"
            onsubmit="return confirm('Delete this tag? It will be removed from all posts.');">
        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
        <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1" title="Delete tag">🗑️</button>
      </form>
    </div>
    {% endif %}
  </div>
  {% endfor %}
</div>
{% else %}
<p class="text-muted">No tags have been created yet.</p>
{% endif %}

{% if session.get('logged_in') %}
<!-- Edit Tag Modal -->
<div class="modal fade" id="editTagModal" tabindex="-1" aria-labelledby="editTagModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="post" id="edit-tag-form">
        <div class="modal-header">
          <h5 class="modal-title" id="editTagModalLabel">Edit Tag</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
          <input type="hidden" name="tag_id" id="edit-tag-id">
          <div class="mb-3">
            <label for="edit-tag-title" class="form-label">Title</label>
            <input type="text" name="title" id="edit-tag-title" class="form-control" required>
          </div>
          <div class="mb-3">
            <label for="edit-tag-color" class="form-label">Color</label>
            <input type="color" name="color" id="edit-tag-color" class="form-control form-control-color"
                   style="width: 60px; height: 38px; padding: 2px;">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  var editTagModal = document.getElementById('editTagModal');
  if (editTagModal) {
    editTagModal.addEventListener('show.bs.modal', function(event) {
      var button = event.relatedTarget;
      var tagId = button.getAttribute('data-tag-id');
      var tagTitle = button.getAttribute('data-tag-title');
      var tagColor = button.getAttribute('data-tag-color');
      document.getElementById('edit-tag-id').value = tagId;
      document.getElementById('edit-tag-title').value = tagTitle;
      document.getElementById('edit-tag-color').value = tagColor;
      document.getElementById('edit-tag-form').action = '/tags/' + tagId + '/edit';
    });
  }
</script>
{% endif %}
{% endblock %}
