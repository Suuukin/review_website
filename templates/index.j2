{% extends 'base.j2' %}
{% from '_macros.j2' import tag_badges %}

{% block content %}
<h1>Reviews</h1>
<form method="get" action="{{ url_for('index') }}" class="mb-4">
  <div class="input-group">
    <input type="search" name="q" class="form-control"
           placeholder="Search by title or tag…"
           value="{{ request.args.get('q', '') | e }}">
    <button class="btn btn-outline-light" type="submit">Search</button>
  </div>
</form>
{% if posts %}
{% for post in posts %}
    {% if post["store"] == "steam" %}
        {% set id = post["app_id"] %}
        {% set image = post["extra"]["capsule_image"] %}
        {% set genres = post["genres"] %}
    {% else %}
        {% set id = post["id"] %}
        {% set image = None %}
        {% set genres = None %}
    {% endif %}
    {% set tags = post["tags"] %}

    <div>
        <a href=" {{url_for('post', post_id=id, store=post['store'])}}"><img
            src="{{image}}" alt="Game Image"></a>
        <a href=" {{url_for('post', post_id=id, store=post['store'])}}"><h2 
            class="p-2" style="display: inline-block">{{ post['title'] }}</h2></a>
    </div>

    {% if genres != None %}
        {% for description in genres %}
            <span class="badge badge-secondary">{{description}}</span>
        {% endfor %}
    {% endif %}

    {% if tags %}
        <div class="vr"></div>
        {{ tag_badges(tags, wrapper_class="") }}
    {% endif %}

    <span class="edit badge badge-primary float-end">{{ post['created'] }}</span>
    <span></span>

    {% if session.get('logged_in') %}
        <a href="{{ url_for('edit', id=id, store=post['store']) }}">
            <span class="badge badge-warning float-end">Edit</span>
        </a>
        <form action="{{ url_for('delete', id=id, store=post['store']) }}" method="POST" class="d-inline float-end">
            <button type="submit" class="badge badge-danger" onclick="return confirm('Are you sure you want to delete this post?')">Delete</button>
        </form>
    {% endif %}

    <hr>
{% endfor %}
{% else %}
<p class="text-muted">No reviews match your search.</p>
{% endif %}
{% endblock %}