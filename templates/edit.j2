{% extends 'base.j2' %}

{% block head %}
{% include 'components/_form_css.j2' %}
{% endblock %}

{% block content %}
<h1 class="mb-4">Edit "{{ post['title'] }}"</h1>

<form method="post" id="edit-form">
    <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input type="text" name="title" id="title" placeholder="Post title" class="form-control"
            value="{{ request.form['title'] or post['title'] }}">
    </div>

    {% include 'components/_tags_form.j2' %}

    <div class="mb-3">
        <label for="content" class="form-label">Content (Markdown)</label>
        <textarea name="content" id="content" class="form-control">{{ request.form['content'] or post['content'] }}</textarea>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Submit</button>
    </div>
</form>

<hr>
{% set delete_id = post['app_id'] if post['store'] == 'steam' else post['id'] %}
<form action="{{ url_for('delete', id=delete_id, store=post['store']) }}" method="POST">
    <input type="submit" value="Delete Post" class="btn btn-danger btn-sm"
        onclick="return confirm('Are you sure you want to delete this post?')">
</form>
{% endblock %}

{% block scripts %}
{% include 'components/_form_js.j2' %}
<script src="{{ url_for('static', filename='js/easymde_init.js') }}"></script>
<script src="{{ url_for('static', filename='js/tag_select.js') }}"></script>
{% if post_tags %}
<script>
    var existingTags = {{ post_tags | tojson }};
    existingTags.forEach(function(tag) {
        tagSelect.addOption(tag);
        tagSelect.addItem(tag.tag_id);
    });
</script>
{% endif %}
{% endblock %}
