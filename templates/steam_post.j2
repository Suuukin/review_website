{% extends 'base.j2' %}

{% block left_panel %}
<div class="left_panel" style="background-image: url('{{bg_img}}')">
</div>
{% endblock %}

{% block content %}
<div class="container p-3">
    <div>
        <a href="{{store_url}}"><img class="store_image float-end" src="{{ url_for('static', filename='images/steam_logo.svg') }}"
                alt="Steam Store Link"></a>
        <h2 class="text-white">{% block title %} {{ post['title'] }} {% endblock %}</h2>
    </div>
    <span class="badge badge-primary">{{ post['created'] }}</span>
    <div class="row">
        <div class="col">
            <h3>My Review</h3>
            {% if tags %}
            <div class="d-flex flex-wrap gap-2 mb-2">
                {% for tag in tags %}
                <span class="tag-badge" style="background-color: {{ tag['color'] or '#4a6984' }};">{{ tag['title'] }}</span>
                {% endfor %}
            </div>
            {% endif %}
            <p>{{ post_content|safe }}</p>
        </div>
        <div class="col d-flex flex-wrap align-items-center">
            <a href="{{store_url}}"><img class="capsule_image border border-primary" src="{{image}}"
                    alt="Game Image"></a>
        </div>
    </div>
    <hr class="p-3">
    <div class="p-4 steam_description">{{desc|safe}}</div>
</div>
{% endblock %}

{% block right_panel %}
<div class="right_panel" style="background-image: url('{{bg_img}}')">
</div>
{% endblock %}
