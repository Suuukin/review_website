{# Reusable Jinja macros #}

{# Renders a single tag badge #}
{% macro tag_badge(tag, query='') %}
<span class="tag-badge" style="background-color: {{ tag['color'] or '#4a6984' }};">{% if query %}{{ tag['title'] | highlight(query) }}{% else %}{{ tag['title'] }}{% endif %}</span>
{% endmacro %}

{# Renders a list of tag badges, optionally wrapped in a flex container #}
{% macro tag_badges(tags, wrapper_class="d-flex flex-wrap gap-2 mb-2", query='') %}
{% if tags %}
{% if wrapper_class %}<div class="{{ wrapper_class }}">{% endif %}
    {% for tag in tags %}
    {{ tag_badge(tag, query) }}
    {% endfor %}
{% if wrapper_class %}</div>{% endif %}
{% endif %}
{% endmacro %}
