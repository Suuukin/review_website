{% extends 'base.j2' %}

{% block head %}
{% include 'components/_form_css.j2' %}
{% endblock %}

{% block content %}
<h1 class="mb-4">Create a New Post</h1>

<form method="post" id="create-form">
    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
    <!-- Post Type Selector -->
    <div class="mb-4">
        <label class="form-label">Post Type</label>
        <div class="d-flex gap-3">
            <div class="form-check">
                <input class="form-check-input" type="radio" name="post_type" id="type-review" value="review">
                <label class="form-check-label" for="type-review">🎮 Game Review</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio" name="post_type" id="type-blog" value="blog" checked>
                <label class="form-check-label" for="type-blog">📝 Blog Post</label>
            </div>
        </div>
    </div>

    <!-- Game search — shown only for Game Review type -->
    <div class="mb-3" id="game-search-section">
        <label for="game-search" class="form-label">Game</label>
        <input type="text" id="game-search" placeholder="Search for a Steam game…" class="form-control" autocomplete="off">
        <input type="hidden" name="app_id" id="app_id" value="">
        <input type="hidden" name="store" id="store" value="steam">
        <div id="game-selected" class="d-none mt-2 p-2 border rounded d-flex align-items-center gap-3">
            <img id="selected-game-image" src="" alt="" class="rounded" style="width: 92px; height: 43px; object-fit: cover;">
            <div>
                <strong id="selected-game-name" class="text-white"></strong>
                <br>
                <small class="text-muted">App ID: <span id="selected-game-appid"></span></small>
            </div>
            <button type="button" id="clear-game" class="btn btn-sm btn-outline-secondary ms-auto">Remove</button>
        </div>
    </div>

    <!-- Title section — shown only for Blog Post type -->
    <div class="mb-3" id="title-section" style="display: none;">
        <label for="title" class="form-label">Title</label>
        <input type="text" name="title" id="title" placeholder="Post title" class="form-control"
            value="{{ request.form['title'] }}">
    </div>

    {% include 'components/_tags_form.j2' %}

    <div class="mb-3">
        <label for="content" class="form-label">Content (Markdown)</label>
        <textarea name="content" id="content" class="form-control">{{ request.form['content'] }}</textarea>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Submit</button>
    </div>
</form>
{% endblock %}

{% block scripts %}
{% include 'components/_form_js.j2' %}
<script src="{{ url_for('static', filename='js/easymde_init.js') }}"></script>
<script src="{{ url_for('static', filename='js/tag_select.js') }}"></script>
<script src="{{ url_for('static', filename='js/game_search.js') }}"></script>
<script src="{{ url_for('static', filename='js/post_type_toggle.js') }}"></script>
{% endblock %}
